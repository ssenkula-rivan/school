# School Management System Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-generate-with-django-get-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database Configuration - PostgreSQL ONLY
# Provide EITHER a DATABASE_URL (preferred for Render/Heroku) OR individual DB_* settings.

# Option 1: Single URL style (Render/Heroku) - RECOMMENDED
# Get this from Render Dashboard → PostgreSQL → Connect → Internal Database URL
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME

# Option 2: Explicit settings (for local development)
DB_NAME=school_management_saas
DB_USER=postgres
DB_PASSWORD=admin@123456
DB_HOST=localhost
DB_PORT=5432

# Cache Configuration (Redis) - Optional
USE_REDIS=False
REDIS_URL=redis://127.0.0.1:6379/1

# Company Information
COMPANY_NAME=Your School Name
COMPANY_EMAIL=admin@yourschool.com
COMPANY_ADDRESS=Your School Address
COMPANY_PHONE=+1-234-567-8900

# Email Configuration
# Get SMTP credentials from your email provider
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password-or-app-password
DEFAULT_FROM_EMAIL=noreply@yourschool.com

# Common SMTP Settings:
# Gmail: smtp.gmail.com, port 587, TLS
# Office 365: smtp.office365.com, port 587, TLS
# Custom Domain: mail.yourdomain.com, port 587 or 465

# File Upload Settings
FILE_UPLOAD_MAX_SIZE=10485760
DATA_UPLOAD_MAX_SIZE=10485760

# Time Zone
TIME_ZONE=UTC

# ============================================================================
# SAAS PLATFORM CONFIGURATION
# ============================================================================

# Site Configuration
SITE_NAME=School Management System
SITE_URL=http://localhost:8000
SUPPORT_EMAIL=support@yourschool.com

# Subscription Settings
DEFAULT_TRIAL_DAYS=14
SUBSCRIPTION_GRACE_PERIOD_DAYS=3

# Payment Gateway Configuration
# Choose one: stripe, flutterwave, paystack
PAYMENT_GATEWAY=stripe

# Stripe Configuration
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Flutterwave Configuration
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-your_public_key
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_secret_key
FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_secret

# Paystack Configuration
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key
PAYSTACK_SECRET_KEY=sk_test_your_secret_key

# Celery Configuration (for background jobs)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Monitoring (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENVIRONMENT=development
